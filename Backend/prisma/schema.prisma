generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id        String   @id @default(uuid())

  fullName  String
  email     String   @unique
  password  String

  age       Int
  gender    Gender
  weight    Float

   workouts  Workout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Workout {

  id        String   @id @default(uuid())

  exercise  String

  sets       Int

  reps       Int

  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

}
